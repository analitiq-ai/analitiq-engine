# Development environment configuration for Docker deployment
# Simulates AWS Batch execution with DynamoDB/S3 config fetching

# === Environment Configuration ===
ENV=dev

# === Pipeline Configuration (passed at runtime) ===
# These should be passed via docker run -e flags
# PIPELINE_ID=22ab7b76-b4df-4c68-8b27-82c307436661
# CLIENT_ID=d7a11991-2795-49d1-a858-c7e58ee5ecc6

# === AWS Configuration ===
AWS_REGION=eu-central-1

# === DynamoDB Table Names ===
PIPELINES_TABLE=pipelines
CONNECTIONS_TABLE=connections
CONNECTORS_TABLE=connectors
ENDPOINTS_TABLE=connectors_endpoints
STREAMS_TABLE=streams

# === S3 Buckets ===
# Secrets bucket (auto-constructed as analitiq-secrets-{env} if not set)
# SECRETS_BUCKET=analitiq-secrets-dev

# Row count metrics bucket
ROW_COUNT_BUCKET=analitiq-client-pipeline-row-count

# === Logging ===
LOG_LEVEL=INFO

# === Local paths (inside container) ===
LOCAL_CONFIG_MOUNT=/config
