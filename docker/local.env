# Environment configuration for Docker deployment
# Copy this file to .env and configure your values

# === Environment Configuration ===
ENV=local

# === Pipeline Configuration ===
PIPELINE_ID=a1b2c3d4-e5f6-7890-abcd-ef1234567890

# === AWS Configuration (for dev/prod environments) ===
AWS_REGION=eu-central-1

# AWS Credentials (only needed for dev/prod, not local)
# In production ECS, these should come from IAM roles
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_SESSION_TOKEN=your_session_token  # Optional

# === DynamoDB Table Names (required for dev/prod environments) ===
# These must be set when ENV=dev or ENV=prod
PIPELINES_TABLE=pipelines
CONNECTIONS_TABLE=connections
CONNECTORS_TABLE=connectors
ENDPOINTS_TABLE=connectors_endpoints
STREAMS_TABLE=streams

# === S3 Buckets ===
ROW_COUNT_BUCKET=analitiq-client-pipeline-row-count

# === Application Secrets ===
# These should be stored in AWS Secrets Manager for prod deployments

# Pipeline configurations
#PROFILE_ID=2496403
#BALANCE_ID=5305253
#WISE_API_TOKEN=60ef5f42-adb2-4ec2-8ce1-39ae5a451e42
#SEVDESK_API_TOKEN=b2230709a1d4c7a212559d937a0f8653
#SEVDESK_BANK_ACCOUNT_ID=5936402

# === Local Development Configuration ===
LOCAL_CONFIG_MOUNT=/config

# === Optional: Advanced Configuration ===
# These have sensible defaults but can be customized

# Logging Level
LOG_LEVEL=INFO

# Monitoring Configuration
# DEFAULT_MONITORING_INTERVAL_SECONDS=5

# Connection Pool Settings
# DB_MIN_CONNECTIONS=2
# DB_MAX_CONNECTIONS=10