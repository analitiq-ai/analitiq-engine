{
  "endpoint": "/v1/transfers",
  "method": "GET",
  "replication_filter_mapping": {
    "created": "createdDateStart"
  },
  "pagination": {
    "type": "offset",
    "params": {
      "limit_param": "limit",
      "max_limit": null,
      "page_param": null,
      "offset_param": "offset",
      "cursor_param": null,
      "next_cursor_field": null,
      "time_window_params": {
        "start_param": null,
        "end_param": null
      },
      "uses_link_header": false
    }
  },
  "response_schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Transfers List",
    "description": "Returns an array of transfer objects for a given profile",
    "type": "array",
    "items": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer",
          "description": "Transfer ID"
        },
        "user": {
          "type": "integer",
          "description": "Your user ID"
        },
        "targetAccount": {
          "type": "integer",
          "description": "Recipient account ID"
        },
        "sourceAccount": {
          "type": "integer",
          "nullable": true,
          "description": "Refund recipient account ID"
        },
        "quote": {
          "type": "integer",
          "nullable": true,
          "description": "v1 quote ID"
        },
        "quoteUuid": {
          "type": "string",
          "description": "v2 quote ID"
        },
        "status": {
          "type": "string",
          "description": "Transfer status"
        },
        "reference": {
          "type": "string",
          "description": "Deprecated, use details.reference instead"
        },
        "rate": {
          "type": "number",
          "description": "Exchange rate value"
        },
        "created": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when transfer was created"
        },
        "business": {
          "type": "integer",
          "nullable": true,
          "description": "Your business profile ID"
        },
        "transferRequest": {
          "type": "integer",
          "nullable": true,
          "description": "Deprecated"
        },
        "details": {
          "type": "object",
          "properties": {
            "reference": {
              "type": "string",
              "description": "Payment reference text"
            }
          }
        },
        "hasActiveIssues": {
          "type": "boolean",
          "description": "Are there any pending issues which stop executing the transfer?"
        },
        "sourceCurrency": {
          "type": "string",
          "description": "Source currency code"
        },
        "sourceValue": {
          "type": "number",
          "description": "Transfer amount in source currency"
        },
        "targetCurrency": {
          "type": "string",
          "description": "Target currency code"
        },
        "targetValue": {
          "type": "number",
          "description": "Transfer amount in target currency"
        },
        "customerTransactionId": {
          "type": "string",
          "description": "Unique identifier randomly generated per transfer request by the calling client"
        },
        "originator": {
          "type": "object",
          "nullable": true,
          "properties": {
            "legalEntityType": {
              "type": "string",
              "description": "Payment originator legal type"
            },
            "reference": {
              "type": "string",
              "description": "Unique customer ID in your system"
            },
            "name": {
              "type": "object",
              "properties": {
                "givenName": {
                  "type": "string",
                  "description": "Payment originator first name"
                },
                "middleNames": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "Payment originator middle name(s)"
                },
                "familyName": {
                  "type": "string",
                  "description": "Payment originator family name"
                },
                "patronymicName": {
                  "type": "string",
                  "nullable": true,
                  "description": "Payment originator patronymic name"
                },
                "fullName": {
                  "type": "string",
                  "description": "Payment originator full legal name"
                }
              }
            },
            "dateOfBirth": {
              "type": "string",
              "format": "date",
              "description": "Payment originator date of birth"
            },
            "businessRegistrationCode": {
              "type": "string",
              "nullable": true,
              "description": "Payment originator business registry or incorporation number"
            },
            "address": {
              "type": "object",
              "properties": {
                "firstLine": {
                  "type": "string",
                  "description": "Payment originator address first line"
                },
                "city": {
                  "type": "string",
                  "description": "Payment originator address city"
                },
                "stateCode": {
                  "type": "string",
                  "nullable": true,
                  "description": "Payment originator address state code"
                },
                "countryCode": {
                  "type": "string",
                  "description": "Payment originator address country code"
                },
                "postCode": {
                  "type": "string",
                  "description": "Payment originator address zip code"
                }
              }
            }
          }
        }
      }
    }
  },
  "filters": {
    "profile": {
      "type": "integer",
      "required": false,
      "operators": [
        "eq"
      ],
      "description": "User profile ID. If parameter is omitted, defaults to user's personal profile"
    },
    "status": {
      "type": "string",
      "required": false,
      "operators": [
        "eq",
        "in"
      ],
      "description": "Comma separated list of one or more status codes to filter transfers"
    },
    "sourceCurrency": {
      "type": "string",
      "required": false,
      "operators": [
        "eq"
      ],
      "description": "Source currency code"
    },
    "targetCurrency": {
      "type": "string",
      "required": false,
      "operators": [
        "eq"
      ],
      "description": "Target currency code"
    },
    "createdDateStart": {
      "type": "string",
      "required": false,
      "operators": [
        "gte"
      ],
      "description": "Starting date to filter transfers, inclusive of the provided date",
      "example": "2018-12-15T00:00:00.000Z"
    },
    "createdDateEnd": {
      "type": "string",
      "required": false,
      "operators": [
        "lte"
      ],
      "description": "Ending date to filter transfers, inclusive of the provided date",
      "example": "2018-12-30T23:59:59.999Z"
    },
    "limit": {
      "type": "integer",
      "required": false,
      "operators": [
        "eq"
      ],
      "description": "Maximum number of records to be returned in response"
    },
    "offset": {
      "type": "integer",
      "required": false,
      "operators": [
        "eq"
      ],
      "description": "Starting record number"
    }
  }
}