{
  "schema": "wise_data",
  "table": "transactions",
  "primary_key": ["id"],
  "unique_constraints": ["id"],
  "configure": {
    "auto_create_schema": true,
    "auto_create_table": true
  },
  "table_schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Wise Transactions Table Schema",
    "description": "PostgreSQL table schema for storing Wise transaction data",
    "type": "object",
    "properties": {
      "id": {
        "type": "integer",
        "description": "Wise transfer ID (primary key)",
        "database_type": "BIGINT",
        "nullable": false,
        "primary_key": true
      },
      "user_id": {
        "type": "integer",
        "description": "User ID",
        "database_type": "BIGINT",
        "nullable": false
      },
      "target_account": {
        "type": "integer",
        "description": "Recipient account ID",
        "database_type": "BIGINT",
        "nullable": false
      },
      "source_account": {
        "type": "integer",
        "description": "Source account ID",
        "database_type": "BIGINT",
        "nullable": true
      },
      "quote": {
        "type": "integer",
        "description": "v1 quote ID",
        "database_type": "BIGINT",
        "nullable": true
      },
      "quote_uuid": {
        "type": "string",
        "description": "v2 quote ID",
        "database_type": "VARCHAR(36)",
        "nullable": true
      },
      "status": {
        "type": "string",
        "description": "Transfer status",
        "database_type": "VARCHAR(50)",
        "nullable": false
      },
      "reference": {
        "type": "string",
        "description": "Legacy reference field",
        "database_type": "TEXT",
        "nullable": true
      },
      "details_reference": {
        "type": "string",
        "description": "Payment reference text",
        "database_type": "TEXT",
        "nullable": true
      },
      "rate": {
        "type": "number",
        "description": "Exchange rate value",
        "database_type": "DECIMAL(10,6)",
        "nullable": true
      },
      "created": {
        "type": "string",
        "format": "date-time",
        "description": "Transaction creation timestamp",
        "database_type": "TIMESTAMPTZ",
        "nullable": false
      },
      "business": {
        "type": "integer",
        "description": "Business profile ID",
        "database_type": "BIGINT",
        "nullable": true
      },
      "has_active_issues": {
        "type": "boolean",
        "description": "Are there any pending issues?",
        "database_type": "BOOLEAN",
        "nullable": false,
        "default": true
      },
      "source_currency": {
        "type": "string",
        "description": "Source currency code",
        "database_type": "VARCHAR(3)",
        "nullable": false,
        "maxLength": 3
      },
      "source_value": {
        "type": "number",
        "description": "Transfer amount in source currency",
        "database_type": "DECIMAL(15,2)",
        "nullable": false
      },
      "target_currency": {
        "type": "string",
        "description": "Target currency code",
        "database_type": "VARCHAR(3)",
        "nullable": false,
        "maxLength": 3
      },
      "target_value": {
        "type": "number",
        "description": "Transfer amount in target currency",
        "database_type": "DECIMAL(15,2)",
        "nullable": false
      },
      "customer_transaction_id": {
        "type": "string",
        "description": "Client-generated unique identifier",
        "database_type": "VARCHAR(255)",
        "nullable": true
      },
      "originator_data": {
        "type": "object",
        "description": "Payment originator information",
        "database_type": "JSONB",
        "nullable": true
      }
    },
    "required": [
      "id",
      "user_id",
      "target_account",
      "status",
      "rate",
      "created",
      "source_currency",
      "source_value",
      "target_currency",
      "target_value"
    ]
  },
  "write_mode": "upsert",
  "conflict_resolution": {
    "on_conflict": "id",
    "action": "update",
    "update_columns": [
      "user_id",
      "target_account",
      "source_account",
      "quote",
      "quote_uuid",
      "status",
      "reference",
      "details_reference",
      "rate",
      "business",
      "has_active_issues",
      "source_currency",
      "source_value",
      "target_currency",
      "target_value",
      "customer_transaction_id"
    ]
  }
}