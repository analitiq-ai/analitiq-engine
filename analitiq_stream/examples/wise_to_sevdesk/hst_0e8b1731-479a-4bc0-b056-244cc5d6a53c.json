{
  "base_url": "https://api.wise.com",
  "type": "api",
  "headers": {
    "Content-Type": "application/json",
    "Accept": "application/json",
    "User-Agent": "AnalitiqStream/1.0",
    "Authorization": "Bearer ${WISE_API_TOKEN}"
  },
  "timeout": 30,
  "max_connections": 10,
  "max_connections_per_host": 3,
  "rate_limit": {
    "max_requests": 60,
    "time_window": 60
  }
}