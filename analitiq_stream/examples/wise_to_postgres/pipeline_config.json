{
  "pipeline_id": "c3a6d6b6-8c3d-4a2a-8c6a-5a9a0a8a8a8a",
  "name": "Wise Multi-Stream to Postgres Integration",
  "version": "1.0",
  "src": {
    "host_id": "0e8b1731-479a-4bc0-b056-244cc5d6a53c",
    "name": "Wise Platform"
  },
  "dst": {
    "host_id": "c3a6d6b6-8c3d-4a2a-8c6a-5a9a0a8a8a8b",
    "name": "SevDesk Platform"
  },
  "engine_config": {
    "batch_size": 100,
    "max_concurrent_batches": 3,
    "buffer_size": 5000,
    "schedule": {
      "type": "interval",
      "interval_minutes": 60,
      "timezone": "UTC"
    }
  },
  "streams": {
    "f1a2b3c4-d5e6-7890-abcd-ef1234567891": {
      "name": "wise-transactions",
      "description": "Wise bank transactions sync",
      "src": {
        "endpoint_id": "5a4b9e21-441f-4bc7-9d5e-41917b4357e6",
        "replication_method": "incremental",
        "cursor_field": "created",
        "cursor_mode": "inclusive",
        "safety_window_seconds": 120,
        "primary_key": ["id"],
        "tie_breaker_fields": ["id"]
      },
      "dst": {
        "endpoint_id": "c3a6d6b6-8c3d-4a2a-8c6a-5a9a0a8a8a8c",
        "refresh_mode": "upsert",
        "batch_support": false,
        "batch_size": 1
      },
      "mapping": {
        "field_mappings": {
          "id": {
            "target": "id",
            "validation": {
              "rules": [{"type": "not_null"}],
              "error_action": "dlq"
            }
          },
          "user": {
            "target": "user_id",
            "validation": {
              "rules": [{"type": "not_null"}],
              "error_action": "dlq"
            }
          },
          "targetAccount": {
            "target": "target_account",
            "validation": {
              "rules": [{"type": "not_null"}],
              "error_action": "dlq"
            }
          },
          "sourceAccount": {
            "target": "source_account"
          },
          "quote": {
            "target": "quote"
          },
          "quoteUuid": {
            "target": "quote_uuid",
            "validation": {
              "rules": [{"type": "not_null"}],
              "error_action": "dlq"
            }
          },
          "status": {
            "target": "status",
            "validation": {
              "rules": [{"type": "not_null"}],
              "error_action": "dlq"
            }
          },
          "reference": {
            "target": "reference"
          },
          "details.reference": {
            "target": "details_reference"
          },
          "rate": {
            "target": "rate",
            "validation": {
              "rules": [{"type": "not_null"}],
              "error_action": "dlq"
            }
          },
          "created": {
            "target": "created",
            "transformations": ["iso_string_to_datetime"],
            "validation": {
              "rules": [{"type": "not_null"}],
              "error_action": "dlq"
            }
          },
          "business": {
            "target": "business"
          },
          "hasActiveIssues": {
            "target": "has_active_issues",
            "validation": {
              "rules": [{"type": "not_null"}],
              "error_action": "dlq"
            }
          },
          "sourceCurrency": {
            "target": "source_currency",
            "validation": {
              "rules": [{"type": "not_null"}],
              "error_action": "dlq"
            }
          },
          "sourceValue": {
            "target": "source_value",
            "validation": {
              "rules": [{"type": "not_null"}],
              "error_action": "dlq"
            }
          },
          "targetCurrency": {
            "target": "target_currency",
            "validation": {
              "rules": [{"type": "not_null"}],
              "error_action": "dlq"
            }
          },
          "targetValue": {
            "target": "target_value",
            "validation": {
              "rules": [{"type": "not_null"}],
              "error_action": "dlq"
            }
          },
          "customerTransactionId": {
            "target": "customer_transaction_id"
          },
          "originator": {
            "target": "originator_data"
          }
        }
      }
    }
  },
  "error_handling": {
    "strategy": "dlq",
    "retry_failed_records": true,
    "max_retries": 3,
    "retry_delay": 5,
    "error_categories": {
      "validation_error": "dlq",
      "transformation_error": "dlq",
      "api_error": "retry",
      "rate_limit_error": "retry_with_backoff"
    }
  },
  "monitoring": {
    "metrics_enabled": true,
    "log_level": "DEBUG",
    "checkpoint_interval": 50,
    "health_check_interval": 300,
    "progress_monitoring": "enabled"
  }
}