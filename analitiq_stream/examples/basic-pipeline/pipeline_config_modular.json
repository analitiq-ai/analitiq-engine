{
  "pipeline_id": "users-sync-pg-to-api",
  "name": "Sync Users from PostgreSQL to API",
  "version": "1.0",
  
  "engine_config": {
    "batch_size": 1000,
    "max_concurrent_batches": 5,
    "buffer_size": 10000,
    "state_file": "state/users_sync_state.json",
    "schedule": {
      "type": "interval",
      "interval_minutes": 15,
      "timezone": "UTC"
    }
  },
  
  "error_handling": {
    "strategy": "dlq",
    "retry_failed_records": true,
    "max_retries": 3,
    "error_categories": {
      "validation_error": "dlq",
      "transformation_error": "dlq",
      "connection_error": "retry",
      "api_error": "retry"
    }
  },
  
  "monitoring": {
    "metrics_enabled": true,
    "log_level": "INFO",
    "checkpoint_interval": 1000,
    "health_check_interval": 300
  }
}