{
  "base_url": "https://api.example.com",
  "auth": {
    "type": "bearer_token",
    "token": "${API_TOKEN}"
  },
  "headers": {
    "Content-Type": "application/json",
    "Accept": "application/json",
    "User-Agent": "AnalitiqStream/1.0"
  },
  "timeout": 30,
  "max_connections": 10,
  "max_connections_per_host": 2,
  "rate_limit": {
    "max_requests": 100,
    "time_window": 60
  }
}