{
  "name": "@analitiq-ai/conversion-matrix",
  "version": "0.1.0",
  "description": "Published Arrow type-conversion policy grid generated by the Analitiq engine: which source->target arrow_type conversions are permitted, and the function an explicit conversion requires. Data only.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./conversion_matrix.json": "./dist/conversion_matrix.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/analitiq-ai/analitiq-engine.git",
    "directory": "packages/conversion-matrix"
  },
  "license": "Apache-2.0",
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
