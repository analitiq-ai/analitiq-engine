# Copy to .env and fill in what you have access to.
# Cloud DB pairs whose credentials are missing skip automatically.

# Snowflake
E2E_SNOWFLAKE_ACCOUNT=
E2E_SNOWFLAKE_USER=
E2E_SNOWFLAKE_PASSWORD=
E2E_SNOWFLAKE_DATABASE=
E2E_SNOWFLAKE_SCHEMA=
E2E_SNOWFLAKE_WAREHOUSE=
E2E_SNOWFLAKE_ROLE=

# BigQuery
E2E_BIGQUERY_PROJECT=
E2E_BIGQUERY_DATASET=
# Path to the service-account JSON file on the host
E2E_BIGQUERY_CREDENTIALS_PATH=

# Redshift
E2E_REDSHIFT_HOST=
E2E_REDSHIFT_PORT=5439
E2E_REDSHIFT_DATABASE=
E2E_REDSHIFT_USER=
E2E_REDSHIFT_PASSWORD=

# ClickHouse Cloud (local ClickHouse runs without this)
E2E_CLICKHOUSE_HOST=
E2E_CLICKHOUSE_PORT=8443
E2E_CLICKHOUSE_USER=
E2E_CLICKHOUSE_PASSWORD=
E2E_CLICKHOUSE_DATABASE=
